---
layout: default
---

<div class="carnival-hero">
  <!-- Centered hero section -->
  <div class="carnival-hero-inner">

    {% if page.profile %}
      {% if page.profile.image %}
        {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
        <div class="carnival-photo-wrap">
          {%
            include figure.liquid
            loading="eager"
            path=profile_image_path
            class="carnival-photo"
            alt=page.profile.image
            cache_bust=true
          %}
        </div>
      {% endif %}
    {% endif %}

    <div class="carnival-name-block">
      <h1 class="carnival-name">
        {% if site.title == 'blank' %}
          {{ site.first_name }} {% if site.middle_name %}{{ site.middle_name }} {% endif %}{{ site.last_name }}
        {% else %}
          {{ site.title }}
        {% endif %}
        <span class="carnival-phd-badge" id="phd-year-badge">PhD Student</span>
      </h1>
      {% if page.subtitle %}
        <p class="carnival-subtitle">{{ page.subtitle }}</p>
      {% endif %}
    </div>

    <div class="carnival-bio">
      {{ content }}
    </div>

    <!-- Social links row -->
    <div class="carnival-links">
      {% if site.email %}
        <a href="mailto:{{ site.email }}" class="carnival-pill-outline">✉ email</a>
      {% endif %}
      {% if site.scholar_userid %}
        <a href="https://scholar.google.com/citations?user={{ site.scholar_userid }}" target="_blank" class="carnival-pill-outline">Google Scholar</a>
      {% endif %}
      {% if site.github_username %}
        <a href="https://github.com/{{ site.github_username }}" target="_blank" class="carnival-pill-outline">GitHub</a>
      {% endif %}
      {% if site.cv_pdf %}
        <a href="{{ site.cv_pdf | relative_url }}" target="_blank" class="carnival-pill-solid">CV ↓</a>
      {% endif %}
    </div>

  </div><!-- end hero inner -->

  <!-- Divider -->
  <hr class="carnival-divider">

</div><!-- end hero -->

<!-- Body sections -->
<div class="carnival-body">

  <!-- Selected papers if enabled -->
  {% if page.selected_papers %}
    <div class="carnival-section">
      <h2 class="carnival-sec-head">selected publications</h2>
      {% include selected_papers.liquid %}
    </div>
  {% endif %}

  <!-- Announcements if enabled -->
  {% if page.announcements and page.announcements.enabled %}
    <div class="carnival-section">
      <h2 class="carnival-sec-head">news</h2>
      {% include news.liquid limit=true %}
    </div>
  {% endif %}

</div>

<!-- PhD year auto-compute -->
<script>
(function() {
  var start = {{ site.phd_start_year | default: 2022 }};
  var diff = new Date().getFullYear() - start + 1;
  var ords = ['1st','2nd','3rd','4th','5th','6th','7th'];
  var badge = document.getElementById('phd-year-badge');
  if (badge) badge.textContent = (ords[diff-1] || diff+'th') + '-year PhD';
})();
</script>
