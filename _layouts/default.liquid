<!doctype html>
<html lang="{{ site.lang }}">
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
  </head>
  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">

    <!-- Network animation canvas -->
    <canvas id="bg-canvas" style="position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"></canvas>

    <!-- Header -->
    {% include header.liquid %}

    <!-- Content -->
    <div class="container mt-5" role="main" style="position:relative;z-index:2;">
      {% if page.toc and page.toc.sidebar %}
        {% if page.toc.sidebar == 'right' %}
          <div class="row">
            <div class="col-sm-9">{{ content }}</div>
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
          </div>
        {% else %}
          <div class="row">
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
            <div class="col-sm-9">{{ content }}</div>
          </div>
        {% endif %}
      {% else %}
        {{ content }}
      {% endif %}
    </div>

    <!-- Footer -->
    {% include footer.liquid %}

    <!-- JavaScripts -->
    {% include scripts.liquid %}

    <!-- Network animation script -->
    <script>
    (function() {
      var canvas = document.getElementById('bg-canvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var W, H, nodes, edges, tick = 0;
      var pal = {
        nodes: ['#26547c','#ef476f','#ffd166','#4a7fa8','#f47d96','#ffe099'],
        bg: ['#eef4fa','#fffbf0'],
        edgeActive: '#ef476f',
        edgeInactive: '#b8cfe0'
      };
      function resize() {
        W = window.innerWidth;
        H = Math.max(document.body.scrollHeight, window.innerHeight);
        canvas.width = W; canvas.height = H;
      }
      function init() {
        resize();
        var count = Math.max(64, Math.floor((W * H) / 14000));
        nodes = Array.from({length: count}, function() { return {
          x: Math.random()*W, y: Math.random()*H,
          r: 2 + Math.random()*3,
          vx: (Math.random()-0.5)*0.22, vy: (Math.random()-0.5)*0.22,
          color: pal.nodes[Math.floor(Math.random()*pal.nodes.length)],
          pulse: Math.random()*Math.PI*2,
          pulseSpeed: 0.01+Math.random()*0.014,
          active: Math.random()<0.15
        }; });
        edges = [];
        for (var i=0;i<count;i++)
          for (var j=i+1;j<count;j++) {
            var dx=nodes[i].x-nodes[j].x, dy=nodes[i].y-nodes[j].y;
            if (Math.sqrt(dx*dx+dy*dy)<150) edges.push([i,j]);
          }
      }
      function draw() {
        ctx.clearRect(0,0,W,H);
        var g=ctx.createLinearGradient(0,0,W,H);
        g.addColorStop(0,pal.bg[0]); g.addColorStop(1,pal.bg[1]);
        ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
        tick++;
        if (tick%65===0) nodes[Math.floor(Math.random()*nodes.length)].active=true;
        nodes.forEach(function(n,i) {
          if (n.active) edges.forEach(function(e) {
            var a=e[0],b=e[1];
            var o=a===i?nodes[b]:b===i?nodes[a]:null;
            if (o&&!o.active&&Math.random()<0.003) o.active=true;
          });
        });
        edges.forEach(function(e) {
          var ni=nodes[e[0]],nj=nodes[e[1]],both=ni.active&&nj.active;
          ctx.beginPath(); ctx.moveTo(ni.x,ni.y); ctx.lineTo(nj.x,nj.y);
          ctx.strokeStyle=both?pal.edgeActive:pal.edgeInactive;
          // edge opacity
          ctx.globalAlpha=both?0.18:0.06;
          ctx.lineWidth=both?1:0.5;
          ctx.stroke(); ctx.globalAlpha=1;
        });
        nodes.forEach(function(n) {
          n.pulse+=n.pulseSpeed;
          n.x+=n.vx; n.y+=n.vy;
          if (n.x<0||n.x>W) n.vx*=-1;
          if (n.y<0||n.y>H) n.vy*=-1;
          var pr=n.r*(n.active?1+0.28*Math.sin(n.pulse):1);
          if (n.active) {
            ctx.beginPath(); ctx.arc(n.x,n.y,pr+5,0,Math.PI*2);
            ctx.fillStyle=n.color; ctx.globalAlpha=0.06; ctx.fill(); ctx.globalAlpha=1;
          }
          ctx.beginPath(); ctx.arc(n.x,n.y,pr,0,Math.PI*2);
          ctx.fillStyle=n.color;
          // node opacity
          ctx.globalAlpha=n.active?0.42:0.16;
          ctx.fill(); ctx.globalAlpha=1;
        });
        requestAnimationFrame(draw);
      }
      window.addEventListener('load', function() {
        init(); draw();
      });
      window.addEventListener('resize', function() { init(); });
    })();
    </script>

  </body>
</html>
